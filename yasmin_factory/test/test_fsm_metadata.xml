<StateMachine outcomes="end" description="Root SM description" name="TestFsmMetadata">
    <Key name="root_param" type="in" default_value="42" default_type="int" description="Root integer param"/>
    <Key name="root_name" type="in" default_value="test" default_type="str" description="Root string param"/>
    <Key name="root_result" type="out" description="Root output"/>
    <Key name="nested_flag" type="in" default_value="true" default_type="bool" description="A boolean flag"/>
    <Key name="nested_rate" type="in" default_value="3.14" default_type="float" description="A float rate"/>
    <Key name="nested_result" type="out" description="Nested output"/>
    <State name="State1" type="cpp" class="yasmin_factory/TestSimpleState">
        <Transition from="outcome1" to="NestedSM"/>
        <Transition from="outcome2" to="end"/>
    </State>
    <FinalOutcome name="end" description="Final outcome"/>
    <StateMachine name="NestedSM" outcomes="nested_done" description="Nested SM description">
        <State name="InnerState" type="cpp" class="yasmin_factory/TestSimpleState">
            <Transition from="outcome1" to="InnerState"/>
            <Transition from="outcome2" to="nested_done"/>
        </State>
        <Transition from="nested_done" to="end"/>
    </StateMachine>
</StateMachine>
